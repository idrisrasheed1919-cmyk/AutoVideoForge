# AI Video Automation System Configuration

# Gemini API (for script generation)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (alternative for script generation)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs API (for voice synthesis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# System settings
DEBUG=false
LOG_LEVEL=INFO
OUTPUT_DIR=./output
TEMP_DIR=./temp
CACHE_DIR=./cache

# Video settings
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
VIDEO_BITRATE=8000k
VIDEO_CODEC=libx264
AUDIO_BITRATE=192k
AUDIO_SAMPLE_RATE=44100

# Script generation
SCRIPT_MIN_LENGTH=100
SCRIPT_MAX_LENGTH=5000
SCRIPT_TOPIC=technology

# Voice settings
VOICE_SPEED=1.0
VOICE_PITCH=1.0

# Rendering
RENDER_TIMEOUT=3600
MAX_PARALLEL_JOBS=2

# File paths
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
